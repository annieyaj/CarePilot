# Copy this file to a new file named `.env` in this same folder (backend/).
# `.env` must be a FILE named exactly `.env` — do not create a folder called `.env`.
# Paste your key on the GEMINI_API_KEY line (no quotes needed).
# Get a key: https://aistudio.google.com/apikey
# Never commit `.env` — it stays on your machine only.

GEMINI_API_KEY=
# Optional — default is gemini-2.5-flash
# GEMINI_MODEL=gemini-2.5-flash

# Browser Use Cloud — https://cloud.browser-use.com/settings
# BROWSER_USE_API_KEY=

# PORT=3001
